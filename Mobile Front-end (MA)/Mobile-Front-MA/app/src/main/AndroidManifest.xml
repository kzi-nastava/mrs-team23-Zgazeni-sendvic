<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- osmdroid checks connectivity before hitting the tile/route servers -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Spec 2.6.3: show Android system notifications for panic alerts (runtime-requested on 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Spec 2.6.3: keep the panic listener alive in the background for admins -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application
        android:name=".MobileFrontApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MobileFrontMA">

        <!-- Login is the entry point of the app -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".activities.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".activities.ForgotPasswordActivity"
            android:exported="false" />
        <activity
            android:name=".activities.ConfirmAccountActivity"
            android:exported="false" />
        <activity
            android:name=".activities.HORDriverActivity"
            android:exported="false" />
        <activity
            android:name=".activities.RideHistoryActivity"
            android:exported="false" />
        <activity
            android:name=".activities.AdminHistoryEntryActivity"
            android:exported="false" />
        <activity
            android:name=".activities.RideHistoryDetailActivity"
            android:exported="false" />
        <activity
            android:name=".activities.PanicNotificationsActivity"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Keeps the panic WebSocket alive in the background for a logged-in admin (spec 2.6.3).
             specialUse: it maintains a connection to receive emergency alerts (no other FGS type
             fits). stopWithTask: swiping the app away stops the listener. -->
        <service
            android:name=".data.realtime.PanicForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:stopWithTask="true">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Maintains a connection to receive emergency panic alerts for administrators" />
        </service>
    </application>

</manifest>