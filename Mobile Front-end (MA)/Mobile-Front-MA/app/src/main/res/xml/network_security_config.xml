<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows plain HTTP (cleartext) only to the local dev backend. On API 28+ cleartext
  is blocked by default, so the Spring server (http://...:8080) would be unreachable
  without this. Production HTTPS hosts are unaffected.

  Hosts:
    - 10.0.2.2  : the host machine as seen from the standard Android emulator
    - localhost / 127.0.0.1 : loopback
  Testing on a PHYSICAL phone? Add your PC's LAN IP (e.g. 192.168.x.x) below and
  set the same IP in ApiClient.BASE_URL.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
</network-security-config>
